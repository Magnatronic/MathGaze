<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ── Colour brushes (design tokens) ── -->
    <SolidColorBrush x:Key="BrushBg"          Color="#F5F3EE"/>
    <SolidColorBrush x:Key="BrushSurface"     Color="#FFFFFF"/>
    <SolidColorBrush x:Key="BrushSurface2"    Color="#FAF8F3"/>
    <SolidColorBrush x:Key="BrushBorder"      Color="#E8E6E0"/>
    <SolidColorBrush x:Key="BrushInk"         Color="#1A1D24"/>
    <SolidColorBrush x:Key="BrushInk2"        Color="#4A4E58"/>
    <SolidColorBrush x:Key="BrushInk3"        Color="#8A8E98"/>
    <SolidColorBrush x:Key="BrushAccent"      Color="#3B6FD4"/>
    <SolidColorBrush x:Key="BrushAccentSoft"  Color="#EEF2FB"/>
    <SolidColorBrush x:Key="BrushAccentInk"   Color="#2A4FA0"/>
    <SolidColorBrush x:Key="BrushExam"        Color="#D94F2A"/>
    <SolidColorBrush x:Key="BrushPractice"    Color="#2CA870"/>
    <SolidColorBrush x:Key="BrushTransparent" Color="Transparent"/>

    <!-- ── Typography ── -->
    <FontFamily x:Key="FontBody">Inter, Segoe UI, sans-serif</FontFamily>
    <FontFamily x:Key="FontMono">JetBrains Mono, Consolas, monospace</FontFamily>

    <!-- ── ToolTile button style (gaze target: 84x56 logical px minimum) ── -->
    <!-- Used by ToolRail stub buttons. No hover/focus chrome that requires drag. -->
    <Style x:Key="ToolTileStyle" TargetType="Button">
        <Setter Property="Width"             Value="84"/>
        <Setter Property="Height"            Value="56"/>
        <Setter Property="Background"        Value="Transparent"/>
        <Setter Property="BorderBrush"       Value="{StaticResource BrushBorder}"/>
        <Setter Property="BorderThickness"   Value="2"/>
        <Setter Property="Foreground"        Value="{StaticResource BrushInk}"/>
        <Setter Property="FontFamily"        Value="{StaticResource FontBody}"/>
        <Setter Property="FontSize"          Value="12"/>
        <Setter Property="FontWeight"        Value="SemiBold"/>
        <Setter Property="Cursor"            Value="Hand"/>
        <Setter Property="FocusVisualStyle"  Value="{x:Null}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="10">
                        <ContentPresenter HorizontalAlignment="Left"
                                          VerticalAlignment="Center"
                                          Margin="12,0,0,0"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="{StaticResource BrushSurface2}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter Property="Background" Value="{StaticResource BrushAccentSoft}"/>
                            <Setter Property="BorderBrush" Value="{StaticResource BrushAccent}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ── TopBar icon button style (36x36 minimum, no border by default) ── -->
    <Style x:Key="IconButtonStyle" TargetType="Button">
        <Setter Property="MinWidth"          Value="36"/>
        <Setter Property="MinHeight"         Value="36"/>
        <Setter Property="Width"             Value="36"/>
        <Setter Property="Height"            Value="36"/>
        <Setter Property="Background"        Value="Transparent"/>
        <Setter Property="BorderBrush"       Value="{StaticResource BrushBorder}"/>
        <Setter Property="BorderThickness"   Value="1.5"/>
        <Setter Property="Foreground"        Value="{StaticResource BrushInk2}"/>
        <Setter Property="Cursor"            Value="Hand"/>
        <Setter Property="FocusVisualStyle"  Value="{x:Null}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="6">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="{StaticResource BrushSurface2}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter Property="Background" Value="{StaticResource BrushAccentSoft}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ── RailButton style: right rail action buttons (nudge pad, delete, undo/redo) ── -->
    <!-- Gaze-safe chrome: white surface, subtle border, no WPF default gray chrome. -->
    <Style x:Key="RailButtonStyle" TargetType="Button">
        <Setter Property="Background"      Value="{StaticResource BrushSurface}"/>
        <Setter Property="BorderBrush"     Value="{StaticResource BrushBorder}"/>
        <Setter Property="BorderThickness" Value="1.5"/>
        <Setter Property="Foreground"      Value="{StaticResource BrushInk}"/>
        <Setter Property="FontFamily"      Value="{StaticResource FontBody}"/>
        <Setter Property="FontSize"        Value="13"/>
        <Setter Property="Cursor"          Value="Hand"/>
        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="6">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource BrushSurface2}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource BrushAccentSoft}"/>
                            <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource BrushAccent}"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.4"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ── StepButton style: nudge step selector (1px / 5px / 20px) ── -->
    <!-- Base appearance matches RailButtonStyle. Active state (Tag="active") -->
    <!-- uses accent cobalt background + white text. Tag is set from RightRail.xaml DataTriggers. -->
    <Style x:Key="StepButtonStyle" TargetType="Button">
        <Setter Property="Background"      Value="{StaticResource BrushSurface}"/>
        <Setter Property="BorderBrush"     Value="{StaticResource BrushBorder}"/>
        <Setter Property="BorderThickness" Value="1.5"/>
        <Setter Property="Foreground"      Value="{StaticResource BrushInk}"/>
        <Setter Property="FontFamily"      Value="{StaticResource FontBody}"/>
        <Setter Property="FontSize"        Value="12"/>
        <Setter Property="FontWeight"      Value="SemiBold"/>
        <Setter Property="Cursor"          Value="Hand"/>
        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="6">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="Tag" Value="active">
                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource BrushAccent}"/>
                            <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource BrushAccent}"/>
                            <Setter Property="Foreground" Value="White"/>
                        </Trigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsMouseOver" Value="True"/>
                                <Condition Property="Tag" Value="active"/>
                            </MultiTrigger.Conditions>
                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource BrushAccentInk}"/>
                        </MultiTrigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsMouseOver" Value="True"/>
                            </MultiTrigger.Conditions>
                            <MultiTrigger.Setters>
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource BrushSurface2}"/>
                            </MultiTrigger.Setters>
                        </MultiTrigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource BrushAccentSoft}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
