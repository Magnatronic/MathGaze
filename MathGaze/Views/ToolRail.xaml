<UserControl x:Class="MathGaze.Views.ToolRail"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="104"
             Background="{StaticResource BrushSurface2}">
    <Border BorderBrush="{StaticResource BrushBorder}" BorderThickness="0,0,1,0">
        <DockPanel>
            <!-- "TOOLS" label -->
            <TextBlock DockPanel.Dock="Top"
                       Text="TOOLS" FontSize="9" FontWeight="Bold"
                       Foreground="{StaticResource BrushAccentInk}"
                       HorizontalAlignment="Center" Margin="0,14,0,8"/>
            <!-- Tool buttons -->
            <StackPanel DockPanel.Dock="Top" HorizontalAlignment="Center" Margin="0,0,0,0">

                <!-- Select -->
                <Button x:Name="SelectButton"
                        Style="{StaticResource ToolTileStyle}" Margin="0,0,0,4"
                        ToolTip="Select tool"
                        Command="{Binding ActivateSelectCommand}">
                    <StackPanel Orientation="Horizontal">
                        <Viewbox Width="24" Height="24" Margin="0,0,10,0">
                            <Canvas Width="24" Height="24">
                                <Path Fill="{StaticResource BrushInk}" Data="M5 3l6 16 2-7 7-2z"/>
                            </Canvas>
                        </Viewbox>
                        <TextBlock Text="Select" VerticalAlignment="Center"
                                   Foreground="{StaticResource BrushInk}"/>
                    </StackPanel>
                </Button>

                <!-- Point -->
                <Button x:Name="PointButton"
                        Style="{StaticResource ToolTileStyle}" Margin="0,0,0,4"
                        ToolTip="Point tool"
                        Command="{Binding ActivatePointCommand}">
                    <StackPanel Orientation="Horizontal">
                        <Viewbox Width="24" Height="24" Margin="0,0,10,0">
                            <Canvas Width="24" Height="24">
                                <Ellipse Canvas.Left="9.5" Canvas.Top="9.5" Width="5" Height="5"
                                         Fill="{StaticResource BrushInk}"/>
                                <Ellipse Canvas.Left="5" Canvas.Top="5" Width="14" Height="14"
                                         Stroke="{StaticResource BrushInk}" StrokeThickness="1.8" Fill="Transparent"/>
                            </Canvas>
                        </Viewbox>
                        <TextBlock Text="Point" VerticalAlignment="Center"
                                   Foreground="{StaticResource BrushInk}"/>
                    </StackPanel>
                </Button>

                <!-- Line -->
                <Button x:Name="LineButton"
                        Style="{StaticResource ToolTileStyle}" Margin="0,0,0,4"
                        ToolTip="Line tool"
                        Command="{Binding ActivateLineCommand}">
                    <StackPanel Orientation="Horizontal">
                        <Viewbox Width="24" Height="24" Margin="0,0,10,0">
                            <Canvas Width="24" Height="24">
                                <Ellipse Canvas.Left="3.5" Canvas.Top="17.5" Width="3" Height="3"
                                         Fill="{StaticResource BrushInk}"/>
                                <Ellipse Canvas.Left="17.5" Canvas.Top="3.5" Width="3" Height="3"
                                         Fill="{StaticResource BrushInk}"/>
                                <Path Stroke="{StaticResource BrushInk}" StrokeThickness="1.8"
                                      StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                      Data="M5 19L19 5"/>
                            </Canvas>
                        </Viewbox>
                        <TextBlock Text="Line" VerticalAlignment="Center"
                                   Foreground="{StaticResource BrushInk}"/>
                    </StackPanel>
                </Button>

                <!-- Circle -->
                <Button x:Name="CircleButton"
                        Style="{StaticResource ToolTileStyle}" Margin="0,0,0,4"
                        ToolTip="Circle tool"
                        Command="{Binding ActivateCircleCommand}">
                    <StackPanel Orientation="Horizontal">
                        <Viewbox Width="24" Height="24" Margin="0,0,10,0">
                            <Canvas Width="24" Height="24">
                                <Ellipse Canvas.Left="4" Canvas.Top="4" Width="16" Height="16"
                                         Stroke="{StaticResource BrushInk}" StrokeThickness="1.8" Fill="Transparent"/>
                                <Ellipse Canvas.Left="11" Canvas.Top="11" Width="2" Height="2"
                                         Fill="{StaticResource BrushInk}"/>
                            </Canvas>
                        </Viewbox>
                        <TextBlock Text="Circle" VerticalAlignment="Center"
                                   Foreground="{StaticResource BrushInk}"/>
                    </StackPanel>
                </Button>

                <!-- Protractor (stub — Phase 3) -->
                <Button Style="{StaticResource ToolTileStyle}" Margin="0,0,0,4" ToolTip="Protractor tool (Phase 3)">
                    <StackPanel Orientation="Horizontal">
                        <Viewbox Width="24" Height="24" Margin="0,0,10,0">
                            <Canvas Width="24" Height="24">
                                <Path Stroke="{StaticResource BrushInk}" StrokeThickness="1.8"
                                      StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                      Fill="Transparent"
                                      Data="M3 16a9 9 0 0 1 18 0"/>
                                <Path Stroke="{StaticResource BrushInk}" StrokeThickness="1.8"
                                      StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                      Data="M3 16h18"/>
                                <Path Stroke="{StaticResource BrushInk}" StrokeThickness="0.8"
                                      Data="M7 16v-1.5M10 16v-2M14 16v-2M17 16v-1.5"/>
                                <Ellipse Canvas.Left="11" Canvas.Top="15" Width="2" Height="2"
                                         Fill="{StaticResource BrushInk}"/>
                            </Canvas>
                        </Viewbox>
                        <TextBlock Text="Protractor" VerticalAlignment="Center"
                                   Foreground="{StaticResource BrushInk}" FontSize="11"/>
                    </StackPanel>
                </Button>

                <!-- Text (stub — Phase 4) -->
                <Button Style="{StaticResource ToolTileStyle}" Margin="0,0,0,4" ToolTip="Text tool (Phase 4)">
                    <StackPanel Orientation="Horizontal">
                        <Viewbox Width="24" Height="24" Margin="0,0,10,0">
                            <Canvas Width="24" Height="24">
                                <Path Stroke="{StaticResource BrushInk}" StrokeThickness="1.8"
                                      StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                      Data="M5 6h14M12 6v13M9 19h6"/>
                            </Canvas>
                        </Viewbox>
                        <TextBlock Text="Text" VerticalAlignment="Center"
                                   Foreground="{StaticResource BrushInk}"/>
                    </StackPanel>
                </Button>

            </StackPanel>
        </DockPanel>
    </Border>
</UserControl>
