<UserControl x:Class="MathGaze.Views.ToolRail"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="108"
             Background="{DynamicResource BrushSurface}">
    <Border BorderBrush="{DynamicResource BrushBorder}" BorderThickness="0,0,1,0">
        <DockPanel>
            <!-- "TOOLS" label -->
            <TextBlock DockPanel.Dock="Top"
                       Text="TOOLS" FontSize="9" FontWeight="Bold"
                       Foreground="{DynamicResource BrushAccentInk}"
                       HorizontalAlignment="Center" Margin="0,14,0,8"/>
            <!-- Tool buttons -->
            <StackPanel DockPanel.Dock="Top" HorizontalAlignment="Center" Margin="0,0,0,0">

                <!-- Select -->
                <Button x:Name="SelectButton"
                        Margin="0,0,0,4"
                        ToolTip="Select tool"
                        Command="{Binding ActivateSelectCommand}">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource ToolTileStyle}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ActiveTool}" Value="Select">
                                    <Setter Property="Background"  Value="{DynamicResource BrushAccentSoft}"/>
                                    <Setter Property="BorderBrush" Value="{DynamicResource BrushAccent}"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                    <StackPanel Orientation="Vertical">
                        <Viewbox Width="32" Height="32" HorizontalAlignment="Center">
                            <Canvas Width="24" Height="24">
                                <Path Fill="{DynamicResource BrushInk}" Data="M5 3l6 16 2-7 7-2z"/>
                            </Canvas>
                        </Viewbox>
                        <TextBlock Text="Select" HorizontalAlignment="Center"
                                   FontSize="13"
                                   Foreground="{DynamicResource BrushInk}"/>
                    </StackPanel>
                </Button>

                <!-- Point -->
                <Button x:Name="PointButton"
                        Margin="0,0,0,4"
                        ToolTip="Point tool"
                        Command="{Binding ActivatePointCommand}">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource ToolTileStyle}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ActiveTool}" Value="Point">
                                    <Setter Property="Background"  Value="{DynamicResource BrushAccentSoft}"/>
                                    <Setter Property="BorderBrush" Value="{DynamicResource BrushAccent}"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                    <StackPanel Orientation="Vertical">
                        <Viewbox Width="32" Height="32" HorizontalAlignment="Center">
                            <Canvas Width="24" Height="24">
                                <Ellipse Canvas.Left="9.5" Canvas.Top="9.5" Width="5" Height="5"
                                         Fill="{DynamicResource BrushInk}"/>
                                <Ellipse Canvas.Left="5" Canvas.Top="5" Width="14" Height="14"
                                         Stroke="{DynamicResource BrushInk}" StrokeThickness="1.8" Fill="Transparent"/>
                            </Canvas>
                        </Viewbox>
                        <TextBlock Text="Point" HorizontalAlignment="Center"
                                   FontSize="13"
                                   Foreground="{DynamicResource BrushInk}"/>
                    </StackPanel>
                </Button>

                <!-- Line -->
                <Button x:Name="LineButton"
                        Margin="0,0,0,4"
                        ToolTip="Line tool"
                        Command="{Binding ActivateLineCommand}">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource ToolTileStyle}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ActiveTool}" Value="Line">
                                    <Setter Property="Background"  Value="{DynamicResource BrushAccentSoft}"/>
                                    <Setter Property="BorderBrush" Value="{DynamicResource BrushAccent}"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                    <StackPanel Orientation="Vertical">
                        <Viewbox Width="32" Height="32" HorizontalAlignment="Center">
                            <Canvas Width="24" Height="24">
                                <Ellipse Canvas.Left="3.5" Canvas.Top="17.5" Width="3" Height="3"
                                         Fill="{DynamicResource BrushInk}"/>
                                <Ellipse Canvas.Left="17.5" Canvas.Top="3.5" Width="3" Height="3"
                                         Fill="{DynamicResource BrushInk}"/>
                                <Path Stroke="{DynamicResource BrushInk}" StrokeThickness="1.8"
                                      StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                      Data="M5 19L19 5"/>
                            </Canvas>
                        </Viewbox>
                        <TextBlock Text="Line" HorizontalAlignment="Center"
                                   FontSize="13"
                                   Foreground="{DynamicResource BrushInk}"/>
                    </StackPanel>
                </Button>

                <!-- Circle -->
                <Button x:Name="CircleButton"
                        Margin="0,0,0,4"
                        ToolTip="Circle tool"
                        Command="{Binding ActivateCircleCommand}">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource ToolTileStyle}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ActiveTool}" Value="Circle">
                                    <Setter Property="Background"  Value="{DynamicResource BrushAccentSoft}"/>
                                    <Setter Property="BorderBrush" Value="{DynamicResource BrushAccent}"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                    <StackPanel Orientation="Vertical">
                        <Viewbox Width="32" Height="32" HorizontalAlignment="Center">
                            <Canvas Width="24" Height="24">
                                <Ellipse Canvas.Left="4" Canvas.Top="4" Width="16" Height="16"
                                         Stroke="{DynamicResource BrushInk}" StrokeThickness="1.8" Fill="Transparent"/>
                                <Ellipse Canvas.Left="11" Canvas.Top="11" Width="2" Height="2"
                                         Fill="{DynamicResource BrushInk}"/>
                            </Canvas>
                        </Viewbox>
                        <TextBlock Text="Circle" HorizontalAlignment="Center"
                                   FontSize="13"
                                   Foreground="{DynamicResource BrushInk}"/>
                    </StackPanel>
                </Button>

                <!-- Protractor -->
                <Button x:Name="ProtractorButton"
                        Margin="0,0,0,4"
                        ToolTip="Protractor tool"
                        Command="{Binding ActivateProtractorCommand}">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource ToolTileStyle}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ActiveTool}" Value="Protractor">
                                    <Setter Property="Background"  Value="{DynamicResource BrushAccentSoft}"/>
                                    <Setter Property="BorderBrush" Value="{DynamicResource BrushAccent}"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                    <StackPanel Orientation="Vertical">
                        <Viewbox Width="32" Height="32" HorizontalAlignment="Center">
                            <Canvas Width="24" Height="24">
                                <Path Stroke="{DynamicResource BrushInk}" StrokeThickness="1.8"
                                      StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                      Fill="Transparent"
                                      Data="M3 16a9 9 0 0 1 18 0"/>
                                <Path Stroke="{DynamicResource BrushInk}" StrokeThickness="1.8"
                                      StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                      Data="M3 16h18"/>
                                <Path Stroke="{DynamicResource BrushInk}" StrokeThickness="0.8"
                                      Data="M7 16v-1.5M10 16v-2M14 16v-2M17 16v-1.5"/>
                                <Ellipse Canvas.Left="11" Canvas.Top="15" Width="2" Height="2"
                                         Fill="{DynamicResource BrushInk}"/>
                            </Canvas>
                        </Viewbox>
                        <TextBlock Text="Protractor" HorizontalAlignment="Center"
                                   FontSize="13"
                                   Foreground="{DynamicResource BrushInk}"/>
                    </StackPanel>
                </Button>

                <!-- Text -->
                <Button Margin="0,0,0,4"
                        ToolTip="Text tool"
                        Command="{Binding ActivateTextCommand}">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource ToolTileStyle}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ActiveTool}" Value="Text">
                                    <Setter Property="Background"  Value="{DynamicResource BrushAccentSoft}"/>
                                    <Setter Property="BorderBrush" Value="{DynamicResource BrushAccent}"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                    <StackPanel Orientation="Vertical">
                        <Viewbox Width="32" Height="32" HorizontalAlignment="Center">
                            <Canvas Width="24" Height="24">
                                <Path Stroke="{DynamicResource BrushInk}" StrokeThickness="1.8"
                                      StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                      Data="M5 6h14M12 6v13M9 19h6"/>
                            </Canvas>
                        </Viewbox>
                        <TextBlock Text="Text" HorizontalAlignment="Center"
                                   FontSize="13"
                                   Foreground="{DynamicResource BrushInk}"/>
                    </StackPanel>
                </Button>

            </StackPanel>
        </DockPanel>
    </Border>
</UserControl>
