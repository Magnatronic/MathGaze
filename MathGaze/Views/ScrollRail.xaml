<UserControl x:Class="MathGaze.Views.ScrollRail"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="38">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Top: PageUp + Up -->
        <Border Grid.Row="0" Background="{StaticResource BrushSurface}"
                BorderBrush="{StaticResource BrushBorder}" BorderThickness="1"
                CornerRadius="10" Padding="4" Margin="0,14,0,4">
            <StackPanel HorizontalAlignment="Center">
                <!-- Page Up — 30x56 minimum gaze target height -->
                <Button Width="30" Height="56" Style="{StaticResource IconButtonStyle}"
                        BorderThickness="0" ToolTip="Page Up"
                        Command="{Binding ScrollPageUpCommand}">
                    <Viewbox Width="16" Height="16">
                        <Canvas Width="24" Height="24">
                            <Path Stroke="{StaticResource BrushInk2}" StrokeThickness="1.8"
                                  StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                  Data="M6 14l6-6 6 6M6 18h12"/>
                        </Canvas>
                    </Viewbox>
                </Button>
                <!-- Up -->
                <Button Width="30" Height="56" Style="{StaticResource IconButtonStyle}"
                        BorderThickness="0" ToolTip="Scroll Up"
                        Command="{Binding ScrollUpCommand}">
                    <Viewbox Width="16" Height="16">
                        <Canvas Width="24" Height="24">
                            <Path Stroke="{StaticResource BrushInk2}" StrokeThickness="1.8"
                                  StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                  Data="M6 15l6-6 6 6"/>
                        </Canvas>
                    </Viewbox>
                </Button>
            </StackPanel>
        </Border>

        <!-- Middle: scroll position indicator (visual only) -->
        <Border Grid.Row="1" Background="{StaticResource BrushSurface2}"
                BorderBrush="{StaticResource BrushBorder}" BorderThickness="1"
                CornerRadius="999" Margin="4">
            <Grid>
                <Rectangle Fill="{StaticResource BrushAccent}" Opacity="0.85"
                           RadiusX="999" RadiusY="999"
                           Width="10" Height="20"
                           VerticalAlignment="Top" Margin="0,10,0,0"/>
            </Grid>
        </Border>

        <!-- Bottom: Down + PageDown -->
        <Border Grid.Row="2" Background="{StaticResource BrushSurface}"
                BorderBrush="{StaticResource BrushBorder}" BorderThickness="1"
                CornerRadius="10" Padding="4" Margin="0,4,0,14">
            <StackPanel HorizontalAlignment="Center">
                <!-- Down -->
                <Button Width="30" Height="56" Style="{StaticResource IconButtonStyle}"
                        BorderThickness="0" ToolTip="Scroll Down"
                        Command="{Binding ScrollDownCommand}">
                    <Viewbox Width="16" Height="16">
                        <Canvas Width="24" Height="24">
                            <Path Stroke="{StaticResource BrushInk2}" StrokeThickness="1.8"
                                  StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                  Data="M6 9l6 6 6-6"/>
                        </Canvas>
                    </Viewbox>
                </Button>
                <!-- Page Down -->
                <Button Width="30" Height="56" Style="{StaticResource IconButtonStyle}"
                        BorderThickness="0" ToolTip="Page Down"
                        Command="{Binding ScrollPageDownCommand}">
                    <Viewbox Width="16" Height="16">
                        <Canvas Width="24" Height="24">
                            <Path Stroke="{StaticResource BrushInk2}" StrokeThickness="1.8"
                                  StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                  Data="M6 6h12M6 10l6 6 6-6"/>
                        </Canvas>
                    </Viewbox>
                </Button>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
