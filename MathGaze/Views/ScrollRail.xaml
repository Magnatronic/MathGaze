<UserControl x:Class="MathGaze.Views.ScrollRail"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="80">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Top: PageUp + Up -->
        <Border Grid.Row="0" Background="{DynamicResource BrushSurface}"
                BorderBrush="{DynamicResource BrushBorder}" BorderThickness="1"
                CornerRadius="10" Padding="4" Margin="0,14,0,4">
            <StackPanel HorizontalAlignment="Center">
                <!-- Page Up — 56x56 gaze target -->
                <Button Width="56" Height="56" Style="{StaticResource IconButtonStyle}"
                        BorderThickness="0" ToolTip="Page Up"
                        Command="{Binding ScrollPageUpCommand}">
                    <Viewbox Width="24" Height="24">
                        <Canvas Width="24" Height="24">
                            <Path Stroke="{DynamicResource BrushInk2}" StrokeThickness="1.8"
                                  StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                  Data="M6 14l6-6 6 6M6 18h12"/>
                        </Canvas>
                    </Viewbox>
                </Button>
                <!-- Up -->
                <Button Width="56" Height="56" Style="{StaticResource IconButtonStyle}"
                        BorderThickness="0" ToolTip="Scroll Up"
                        Command="{Binding ScrollUpCommand}">
                    <Viewbox Width="24" Height="24">
                        <Canvas Width="24" Height="24">
                            <Path Stroke="{DynamicResource BrushInk2}" StrokeThickness="1.8"
                                  StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                  Data="M6 15l6-6 6 6"/>
                        </Canvas>
                    </Viewbox>
                </Button>
            </StackPanel>
        </Border>

        <!-- Middle: scroll position indicator (proportional thumb) -->
        <Border Grid.Row="1" Background="{DynamicResource BrushBorder}"
                BorderThickness="0"
                CornerRadius="4"
                Margin="20,4"
                x:Name="ScrollTrack"
                SizeChanged="OnTrackSizeChanged">
            <Canvas x:Name="ThumbCanvas" ClipToBounds="True">
                <Rectangle x:Name="ScrollThumb"
                           Fill="{DynamicResource BrushInk2}"
                           Opacity="0.25"
                           Width="10" Height="0"
                           RadiusX="4" RadiusY="4"
                           Canvas.Left="0" Canvas.Top="0"/>
            </Canvas>
        </Border>

        <!-- Bottom: Down + PageDown -->
        <Border Grid.Row="2" Background="{DynamicResource BrushSurface}"
                BorderBrush="{DynamicResource BrushBorder}" BorderThickness="1"
                CornerRadius="10" Padding="4" Margin="0,4,0,14">
            <StackPanel HorizontalAlignment="Center">
                <!-- Down -->
                <Button Width="56" Height="56" Style="{StaticResource IconButtonStyle}"
                        BorderThickness="0" ToolTip="Scroll Down"
                        Command="{Binding ScrollDownCommand}">
                    <Viewbox Width="24" Height="24">
                        <Canvas Width="24" Height="24">
                            <Path Stroke="{DynamicResource BrushInk2}" StrokeThickness="1.8"
                                  StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                  Data="M6 9l6 6 6-6"/>
                        </Canvas>
                    </Viewbox>
                </Button>
                <!-- Page Down -->
                <Button Width="56" Height="56" Style="{StaticResource IconButtonStyle}"
                        BorderThickness="0" ToolTip="Page Down"
                        Command="{Binding ScrollPageDownCommand}">
                    <Viewbox Width="24" Height="24">
                        <Canvas Width="24" Height="24">
                            <Path Stroke="{DynamicResource BrushInk2}" StrokeThickness="1.8"
                                  StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                  Data="M6 6h12M6 10l6 6 6-6"/>
                        </Canvas>
                    </Viewbox>
                </Button>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
