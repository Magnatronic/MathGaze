<UserControl x:Class="MathGaze.Views.RightRail"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="180"
             Background="{DynamicResource BrushSurface}">
    <Border BorderBrush="{DynamicResource BrushBorder}" BorderThickness="1,0,0,0">
        <DockPanel LastChildFill="True">

            <!-- ── UNDO / REDO footer — always visible, bottommost ────────────── -->
            <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal"
                        HorizontalAlignment="Center" Margin="0,8">
                <Button Width="56" Height="56"
                        Style="{StaticResource RailButtonStyle}"
                        Command="{Binding UndoCommand}"
                        ToolTip="Undo"
                        Content="&#x21A9;" FontSize="20" Margin="0,0,4,0"/>
                <Button Width="56" Height="56"
                        Style="{StaticResource RailButtonStyle}"
                        Command="{Binding RedoCommand}"
                        ToolTip="Redo"
                        Content="&#x21AA;" FontSize="20"/>
            </StackPanel>

            <!-- ── CLEAR PAGE — always visible, above undo/redo (D-08) ────────── -->
            <StackPanel DockPanel.Dock="Bottom" Margin="8,0,8,4">
                <Button Height="56"
                        HorizontalAlignment="Stretch"
                        Style="{StaticResource DeleteButtonStyle}"
                        Command="{Binding ClearPageCommand}"
                        Content="Clear page"
                        FontSize="13"
                        Background="#CC2020"
                        Foreground="White"
                        ToolTip="Remove all objects on this page (undoable)"/>
            </StackPanel>

            <!-- ── MAIN CONTENT ──────────────────────────────────────────────── -->
            <StackPanel Margin="8,14,8,0">

                <!-- ── DRAWING GUIDE PANEL (shown when HasDrawingInProgress = true) ── -->
                <Border Visibility="{Binding HasDrawingInProgress, Converter={StaticResource BoolToVisibilityConverter}}"
                        Margin="0,0,0,8">
                    <StackPanel>
                        <Border CornerRadius="10"
                                BorderBrush="{DynamicResource BrushAccent}"
                                BorderThickness="1.5"
                                Padding="10,12"
                                Margin="0,0,0,8">
                            <TextBlock Text="{Binding DrawingInstructionText}"
                                       FontSize="14" Foreground="{DynamicResource BrushInk2}"
                                       TextWrapping="Wrap" LineHeight="16"
                                       TextAlignment="Center"/>
                        </Border>
                        <!-- Cancel button — >=56x56px, resets draw state (D-01) -->
                        <Button Height="56"
                                HorizontalAlignment="Stretch"
                                Style="{StaticResource RailButtonStyle}"
                                Command="{Binding CancelDrawCommand}"
                                Content="Cancel"
                                FontSize="13"
                                ToolTip="Cancel current draw operation"/>
                    </StackPanel>
                </Border>

                <!-- ── OBJECT LIST PANEL (Select tool + nothing selected, D-18) ────────── -->
                <Border Visibility="{Binding HasObjectList, Converter={StaticResource BoolToVisibilityConverter}}"
                        Margin="0,0,0,8">
                    <StackPanel>
                        <!-- Empty state: dashed box when no objects exist (D-20) -->
                        <Grid>
                            <Grid.Style>
                                <Style TargetType="Grid">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ObjectList.Count}" Value="0">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Grid.Style>
                            <Rectangle RadiusX="10" RadiusY="10"
                                       Stroke="{DynamicResource BrushBorder}" StrokeThickness="1.5"
                                       StrokeDashArray="4,4" Fill="Transparent"
                                       Height="80"/>
                            <StackPanel Margin="10,14">
                                <TextBlock Text="NO OBJECTS"
                                           FontSize="9" FontWeight="Bold"
                                           Foreground="{DynamicResource BrushInk3}"
                                           Margin="0,0,0,4"/>
                                <TextBlock Text="No objects on this page."
                                           FontSize="13" Foreground="{DynamicResource BrushInk2}"
                                           TextWrapping="Wrap" LineHeight="15"/>
                            </StackPanel>
                        </Grid>

                        <!-- Object list (only when objects exist) -->
                        <ScrollViewer VerticalScrollBarVisibility="Hidden"
                                      HorizontalScrollBarVisibility="Disabled"
                                      MaxHeight="260"
                                      CanContentScroll="False">
                            <ItemsControl ItemsSource="{Binding ObjectList}">
                                <ItemsControl.Style>
                                    <Style TargetType="ItemsControl">
                                        <Setter Property="Visibility" Value="Visible"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding ObjectList.Count}" Value="0">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </ItemsControl.Style>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <!-- Each row: >=44px tall, full-width tap target (D-18, D-19) -->
                                        <Button Height="48"
                                                HorizontalAlignment="Stretch"
                                                HorizontalContentAlignment="Left"
                                                Style="{StaticResource RailButtonStyle}"
                                                Command="{Binding SelectCommand}"
                                                Margin="0,0,0,3"
                                                ToolTip="{Binding DisplayName}">
                                            <StackPanel Orientation="Horizontal" Margin="8,0">
                                                <!-- Display name only — type chip removed (UAT fix: "Line Line 1" → "Line 1") -->
                                                <TextBlock Text="{Binding DisplayName}"
                                                           FontSize="13"
                                                           Foreground="{DynamicResource BrushInk}"
                                                           VerticalAlignment="Center"
                                                           Margin="4,0"/>
                                            </StackPanel>
                                        </Button>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </StackPanel>
                </Border>

                <!-- ── SELECTION PANEL (shown when HasSelectionPanel = true) ──────── -->
                <StackPanel Visibility="{Binding HasSelectionPanel, Converter={StaticResource BoolToVisibilityConverter}}">

                    <!-- Selection type label -->
                    <TextBlock Text="{Binding SelectedObjectType}"
                               FontSize="14" FontWeight="Bold"
                               Foreground="{DynamicResource BrushInk3}"
                               Margin="0,0,0,10"
                               HorizontalAlignment="Center"/>

                    <!-- PROTRACTOR PANEL (shown only when SelectedObjectType == "Protractor") -->
                    <StackPanel x:Name="ProtractorPanel" Margin="0,0,0,8">
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedObjectType}" Value="Protractor">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>

                        <!-- Rotate section label -->
                        <TextBlock Text="ROTATE"
                                   FontSize="9" FontWeight="Bold"
                                   Foreground="{DynamicResource BrushInk3}"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,4"/>

                        <!-- Rotate block: −5°, −1°, +1°, +5° — fill rail width to match style buttons -->
                        <UniformGrid Rows="2" Columns="2" Margin="0,0,0,6">
                            <Button Height="56"
                                    Style="{StaticResource RailButtonStyle}"
                                    Command="{Binding RotateMinus5Command}"
                                    Content="&#x2212;5&#xB0;"
                                    ToolTip="Rotate left 5 degrees"/>
                            <Button Height="56"
                                    Style="{StaticResource RailButtonStyle}"
                                    Command="{Binding RotateMinus1Command}"
                                    Content="&#x2212;1&#xB0;"
                                    ToolTip="Rotate left 1 degree"/>
                            <Button Height="56"
                                    Style="{StaticResource RailButtonStyle}"
                                    Command="{Binding RotatePlus1Command}"
                                    Content="+1&#xB0;"
                                    ToolTip="Rotate right 1 degree"/>
                            <Button Height="56"
                                    Style="{StaticResource RailButtonStyle}"
                                    Command="{Binding RotatePlus5Command}"
                                    Content="+5&#xB0;"
                                    ToolTip="Rotate right 5 degrees"/>
                        </UniformGrid>

                        <!-- Flip scale / Flip row — two half-width buttons matching style row -->
                        <UniformGrid Rows="1" Columns="2" Margin="0,0,0,6">
                            <Button Height="56"
                                    Style="{StaticResource RailButtonStyle}"
                                    Command="{Binding FlipScaleCommand}"
                                    Content="Flip scale"
                                    ToolTip="Toggle inner/outer scale (0–180 or 180–0)"/>
                            <Button Height="56"
                                    Style="{StaticResource RailButtonStyle}"
                                    Command="{Binding FlipProtractorCommand}"
                                    Content="Flip"
                                    ToolTip="Flip protractor 180°"/>
                        </UniformGrid>

                        <!-- Style toggle: Classic 180° / Full 360° — StepButtonStyle pattern with Tag="active" -->
                        <TextBlock Text="STYLE"
                                   FontSize="9" FontWeight="Bold"
                                   Foreground="{DynamicResource BrushInk3}"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,4"/>
                        <UniformGrid Rows="1" Columns="2" Margin="0,0,0,6">
                            <Button Height="40"
                                    Command="{Binding SetStyleClassicCommand}"
                                    Content="180&#xB0;"
                                    ToolTip="Classic 180-degree protractor">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource StepButtonStyle}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsStyleClassic}" Value="True">
                                                <Setter Property="Tag" Value="active"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                            <Button Height="40"
                                    Command="{Binding SetStyleFullCommand}"
                                    Content="360&#xB0;"
                                    ToolTip="Full 360-degree protractor (for bearings)">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource StepButtonStyle}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsStyleFull}" Value="True">
                                                <Setter Property="Tag" Value="active"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </UniformGrid>

                        <!-- Separator before nudge section -->
                        <Separator Margin="0,4,0,8"/>

                    </StackPanel>

                    <!-- ── NUDGE BLOCK ──────────────────────────────────────── -->

                    <!-- Nudge label (D-07) -->
                    <TextBlock Text="{Binding NudgeLabel}"
                               FontSize="14" Foreground="{DynamicResource BrushInk2}"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,6"
                               TextWrapping="Wrap"/>

                    <!-- Step selector row: 1 / 5 / 20 px -->
                    <UniformGrid Rows="1" Columns="3" Margin="0,0,0,6">
                        <Button Height="40"
                                Command="{Binding SetStepCommand}" CommandParameter="1"
                                Content="1px">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource StepButtonStyle}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding NudgeStepPx}" Value="1">
                                            <Setter Property="Tag" Value="active"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                        <Button Height="40"
                                Command="{Binding SetStepCommand}" CommandParameter="5"
                                Content="5px">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource StepButtonStyle}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding NudgeStepPx}" Value="5">
                                            <Setter Property="Tag" Value="active"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                        <Button Height="40"
                                Command="{Binding SetStepCommand}" CommandParameter="20"
                                Content="20px">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource StepButtonStyle}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding NudgeStepPx}" Value="20">
                                            <Setter Property="Tag" Value="active"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </UniformGrid>

                    <!-- UDLR directional pad (3x3 grid with centre empty) -->
                    <!-- Each button >=56x56px per CLAUDE.md gaze requirement -->
                    <UniformGrid Rows="3" Columns="3" HorizontalAlignment="Center" Margin="0,0,0,10">
                        <!-- Row 1 -->
                        <Rectangle/>
                        <Button Width="56" Height="56"
                                Style="{StaticResource RailButtonStyle}"
                                Command="{Binding NudgeUpCommand}"
                                Content="&#x25B2;" FontSize="16"
                                ToolTip="Nudge up"/>
                        <Rectangle/>
                        <!-- Row 2 -->
                        <Button Width="56" Height="56"
                                Style="{StaticResource RailButtonStyle}"
                                Command="{Binding NudgeLeftCommand}"
                                Content="&#x25C0;" FontSize="16"
                                ToolTip="Nudge left"/>
                        <Rectangle/>
                        <Button Width="56" Height="56"
                                Style="{StaticResource RailButtonStyle}"
                                Command="{Binding NudgeRightCommand}"
                                Content="&#x25B6;" FontSize="16"
                                ToolTip="Nudge right"/>
                        <!-- Row 3 -->
                        <Rectangle/>
                        <Button Width="56" Height="56"
                                Style="{StaticResource RailButtonStyle}"
                                Command="{Binding NudgeDownCommand}"
                                Content="&#x25BC;" FontSize="16"
                                ToolTip="Nudge down"/>
                        <Rectangle/>
                    </UniformGrid>

                    <!-- Delete button — 56px height minimum -->
                    <Button Height="56"
                            Style="{StaticResource DeleteButtonStyle}"
                            Command="{Binding DeleteCommand}"
                            Content="Delete"
                            FontSize="13"
                            Background="#CC2020"
                            Foreground="White"
                            HorizontalAlignment="Stretch"/>
                </StackPanel>

            </StackPanel>
        </DockPanel>
    </Border>
</UserControl>
