<UserControl x:Class="MathGaze.Views.TopBar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Height="72"
             Background="{DynamicResource BrushSurface}">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>
    <Border BorderBrush="{DynamicResource BrushBorder}" BorderThickness="0,0,0,1">
        <DockPanel Margin="16,0" LastChildFill="False">

            <!-- 1. Branding pill -->
            <Border DockPanel.Dock="Left" VerticalAlignment="Center"
                    BorderBrush="{DynamicResource BrushBorder}" BorderThickness="1.5"
                    CornerRadius="8" Margin="0,0,10,0">
                <StackPanel Orientation="Horizontal" Margin="6,6,10,6">
                    <Border Width="28" Height="28" CornerRadius="6"
                            Background="{StaticResource BrushAccent}"
                            Margin="0,0,8,0">
                        <TextBlock Text="M" FontSize="14" FontWeight="Black"
                                   Foreground="White" HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="MathGaze" FontSize="14" FontWeight="Bold"
                               Foreground="{DynamicResource BrushInk}"
                               VerticalAlignment="Center" Margin="0,0,4,0"/>
                </StackPanel>
            </Border>

            <!-- 2. File chip -->
            <Border DockPanel.Dock="Left" VerticalAlignment="Center"
                    Background="{DynamicResource BrushSurface2}"
                    BorderBrush="{DynamicResource BrushBorder}" BorderThickness="1"
                    CornerRadius="8" Margin="0,0,10,0">
                <StackPanel Orientation="Horizontal" Margin="12,4,4,4">
                    <!-- File icon 14x14 -->
                    <Viewbox Width="14" Height="14" Margin="0,0,6,0">
                        <Canvas Width="24" Height="24">
                            <Path Stroke="{DynamicResource BrushInk2}" StrokeThickness="1.8"
                                  StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                  Data="M7 3h8l5 5v13H7z"/>
                            <Path Stroke="{DynamicResource BrushInk2}" StrokeThickness="1.8"
                                  Data="M15 3v5h5"/>
                        </Canvas>
                    </Viewbox>
                    <!-- Filename -->
                    <TextBlock x:Name="FileNameText"
                               Text="{Binding FileName, TargetNullValue='No file open'}"
                               FontFamily="{StaticResource FontMono}" FontSize="11"
                               Foreground="{DynamicResource BrushInk2}"
                               VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <!-- Open button -->
                    <Button x:Name="OpenButton" Width="56" Height="56"
                            Style="{StaticResource IconButtonStyle}"
                            ToolTip="Open PDF"
                            Command="{Binding OpenFileCommand}">
                        <Viewbox Width="24" Height="24">
                            <Canvas Width="24" Height="24">
                                <Path Stroke="{DynamicResource BrushInk2}" StrokeThickness="1.8"
                                      StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                      Data="M3 7a2 2 0 0 1 2-2h4l2 2h8a2 2 0 0 1 2 2v9a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/>
                            </Canvas>
                        </Viewbox>
                    </Button>
                    <!-- Close button -->
                    <Button x:Name="CloseButton" Width="56" Height="56"
                            Style="{StaticResource IconButtonStyle}"
                            ToolTip="Close PDF"
                            Command="{Binding CloseFileCommand}"
                            IsEnabled="{Binding IsPdfOpen}">
                        <Viewbox Width="24" Height="24">
                            <Canvas Width="24" Height="24">
                                <Path Stroke="{DynamicResource BrushInk2}" StrokeThickness="1.8"
                                      StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                      Data="M6 6l12 12M18 6L6 18"/>
                            </Canvas>
                        </Viewbox>
                    </Button>
                </StackPanel>
            </Border>

            <!-- 3. Export PDF button — D-07: top bar, ≥56×56px gaze floor -->
            <Border DockPanel.Dock="Left" VerticalAlignment="Center"
                    Background="{DynamicResource BrushSurface2}"
                    BorderBrush="{DynamicResource BrushBorder}" BorderThickness="1"
                    CornerRadius="8" Margin="0,0,10,0">
                <Button Width="56" Height="56"
                        Style="{StaticResource IconButtonStyle}"
                        ToolTip="Export annotated PDF"
                        Command="{Binding ExportPdfCommand}">
                    <!-- PDF + down-arrow icon: document outline with a downward arrow -->
                    <StackPanel Orientation="Vertical" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Viewbox Width="24" Height="24" Margin="0,0,0,2">
                            <Canvas Width="24" Height="24">
                                <!-- Arrow down -->
                                <Path Stroke="{DynamicResource BrushInk2}" StrokeThickness="1.8"
                                      StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                      Data="M12 3v12M7 11l5 5 5-5M5 19h14"/>
                            </Canvas>
                        </Viewbox>
                        <TextBlock Text="PDF" FontSize="9" FontWeight="SemiBold"
                                   Foreground="{DynamicResource BrushInk2}"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </Border>

            <!-- Settings button (right-docked) -->
            <Button DockPanel.Dock="Right" Width="56" Height="56"
                    Style="{StaticResource IconButtonStyle}"
                    VerticalAlignment="Center" Margin="10,0,0,0"
                    Command="{Binding SettingsVm.OpenSettingsCommand}"
                    ToolTip="Settings">
                <Viewbox Width="24" Height="24">
                    <Canvas Width="24" Height="24">
                        <Path Stroke="{DynamicResource BrushInk2}" StrokeThickness="1.8"
                              StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                              Data="M12 2v3M12 19v3M4.2 4.2l2.1 2.1M17.7 17.7l2.1 2.1M2 12h3M19 12h3M4.2 19.8l2.1-2.1M17.7 6.3l2.1-2.1"/>
                        <Ellipse Canvas.Left="9" Canvas.Top="9" Width="6" Height="6"
                                 Stroke="{DynamicResource BrushInk2}" StrokeThickness="1.8"/>
                    </Canvas>
                </Viewbox>
            </Button>

            <!-- Page navigation strip (right-docked) -->
            <Border DockPanel.Dock="Right" VerticalAlignment="Center"
                    BorderBrush="{DynamicResource BrushBorder}" BorderThickness="1.5"
                    CornerRadius="8" Margin="10,0,0,0">
                <StackPanel Orientation="Horizontal" Margin="3">
                    <!-- Prev page -->
                    <Button Width="56" Height="56" Style="{StaticResource IconButtonStyle}"
                            BorderThickness="0" ToolTip="Previous page"
                            Command="{Binding PreviousPageCommand}">
                        <Viewbox Width="24" Height="24">
                            <Canvas Width="24" Height="24">
                                <Path Stroke="{DynamicResource BrushInk2}" StrokeThickness="1.8"
                                      StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                      Data="M15 6l-6 6 6 6M8 6v12"/>
                            </Canvas>
                        </Viewbox>
                    </Button>
                    <!-- Page counter -->
                    <TextBlock Text="{Binding PageLabel}"
                               FontFamily="{StaticResource FontMono}" FontSize="14"
                               Foreground="{DynamicResource BrushInk}" FontWeight="SemiBold"
                               VerticalAlignment="Center" Margin="4,0" MinWidth="52"
                               TextAlignment="Center"/>
                    <!-- Next page -->
                    <Button Width="56" Height="56" Style="{StaticResource IconButtonStyle}"
                            BorderThickness="0" ToolTip="Next page"
                            Command="{Binding NextPageCommand}">
                        <Viewbox Width="24" Height="24">
                            <Canvas Width="24" Height="24">
                                <Path Stroke="{DynamicResource BrushInk2}" StrokeThickness="1.8"
                                      StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                      Data="M9 6l6 6-6 6M16 6v12"/>
                            </Canvas>
                        </Viewbox>
                    </Button>
                </StackPanel>
            </Border>

            <!-- Zoom strip (right-docked) -->
            <Border DockPanel.Dock="Right" VerticalAlignment="Center"
                    BorderBrush="{DynamicResource BrushBorder}" BorderThickness="1.5"
                    CornerRadius="8" Margin="10,0,0,0">
                <StackPanel Orientation="Horizontal" Margin="3">
                    <!-- Zoom out -->
                    <Button Width="56" Height="56" Style="{StaticResource IconButtonStyle}"
                            BorderThickness="0" ToolTip="Zoom out"
                            Command="{Binding ZoomOutCommand}">
                        <Viewbox Width="24" Height="24">
                            <Canvas Width="24" Height="24">
                                <Path Stroke="{DynamicResource BrushInk2}" StrokeThickness="1.8"
                                      StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                      Data="M5 12h14"/>
                            </Canvas>
                        </Viewbox>
                    </Button>
                    <!-- Zoom label -->
                    <TextBlock Text="{Binding ZoomLabel}"
                               FontFamily="{StaticResource FontMono}" FontSize="14"
                               Foreground="{DynamicResource BrushInk}" FontWeight="SemiBold"
                               VerticalAlignment="Center" MinWidth="42" TextAlignment="Center"
                               Margin="6,0"/>
                    <!-- Zoom in -->
                    <Button Width="56" Height="56" Style="{StaticResource IconButtonStyle}"
                            BorderThickness="0" ToolTip="Zoom in"
                            Command="{Binding ZoomInCommand}">
                        <Viewbox Width="24" Height="24">
                            <Canvas Width="24" Height="24">
                                <Path Stroke="{DynamicResource BrushInk2}" StrokeThickness="1.8"
                                      StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                      Data="M12 5v14M5 12h14"/>
                            </Canvas>
                        </Viewbox>
                    </Button>
                    <!-- Divider -->
                    <Rectangle Width="1" Height="18" Fill="{DynamicResource BrushBorder}" Margin="2,0"/>
                    <!-- Fit page -->
                    <Button Width="56" Height="56" Style="{StaticResource IconButtonStyle}"
                            BorderThickness="0" ToolTip="Fit page"
                            Command="{Binding FitPageCommand}">
                        <Viewbox Width="24" Height="24">
                            <Canvas Width="24" Height="24">
                                <Path Stroke="{DynamicResource BrushInk2}" StrokeThickness="1.8"
                                      StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                      Data="M4 9V5h4M20 9V5h-4M4 15v4h4M20 15v4h-4"/>
                            </Canvas>
                        </Viewbox>
                    </Button>
                </StackPanel>
            </Border>

        </DockPanel>
    </Border>
</UserControl>
