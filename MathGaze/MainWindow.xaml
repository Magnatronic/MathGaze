<Window x:Class="MathGaze.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:MathGaze.Views"
        xmlns:vm="clr-namespace:MathGaze.ViewModels"
        Title="MathGaze" Height="800" Width="1280"
        MinHeight="600" MinWidth="900"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource BrushBg}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="72"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- TopBar — spans full width, row 0 -->
        <views:TopBar Grid.Row="0"
                      DataContext="{Binding}"
                      Panel.ZIndex="3"/>

        <!-- Content area — row 1 -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="108"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="180"/>
            </Grid.ColumnDefinitions>

            <!-- Left tool rail — DataContext set in code-behind to ToolViewModel -->
            <views:ToolRail Grid.Column="0" x:Name="ToolRailControl" Panel.ZIndex="2"/>

            <!-- Centre: canvas — DataContext is set in code-behind to PdfCanvasViewModel -->
            <!-- Right margin reserves space for the 80px ScrollRail so it never overlaps page content -->
            <views:PdfCanvas Grid.Column="1" x:Name="PdfCanvasView" Margin="0,0,80,0"/>

            <!-- ScrollRail overlaid on right edge of canvas, inside canvas column -->
            <views:ScrollRail Grid.Column="1"
                              HorizontalAlignment="Right"
                              VerticalAlignment="Stretch"
                              DataContext="{Binding}"
                              Margin="0,0,0,0"
                              Panel.ZIndex="2"/>

            <!-- Right rail -->
            <views:RightRail x:Name="RightRailControl" Grid.Column="2" Panel.ZIndex="2"/>

            <!-- Settings panel overlay — covers right rail area (D-04) -->
            <!-- Width matches the right rail column (148px). Z-order above right rail. -->
            <!-- Grid 3 compatible: in-window element, no secondary HWND, no Popup. -->
            <Border x:Name="SettingsPanelOverlay"
                    Grid.Column="2"
                    Panel.ZIndex="10"
                    Background="{DynamicResource BrushSurface}"
                    BorderBrush="{DynamicResource BrushBorder}"
                    BorderThickness="1,0,0,0"
                    Visibility="{Binding SettingsVm.IsSettingsPanelOpen, Converter={StaticResource BoolToVisibilityConverter}}">
                <DockPanel Margin="8,14,8,0">

                    <!-- Header: SETTINGS label + close button -->
                    <DockPanel DockPanel.Dock="Top" Margin="0,0,0,12">
                        <Button DockPanel.Dock="Right"
                                Width="56" Height="56"
                                Style="{StaticResource RailButtonStyle}"
                                Command="{Binding SettingsVm.CloseSettingsCommand}"
                                Content="&#x2715;"
                                FontSize="16"
                                ToolTip="Close settings"/>
                        <TextBlock Text="SETTINGS"
                                   FontSize="9" FontWeight="Bold"
                                   Foreground="{DynamicResource BrushInk3}"
                                   VerticalAlignment="Center"/>
                    </DockPanel>

                    <!-- Theme section -->
                    <StackPanel DockPanel.Dock="Top">
                        <TextBlock Text="THEME"
                                   FontSize="9" FontWeight="Bold"
                                   Foreground="{DynamicResource BrushInk3}"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,8"/>
                        <!-- Light / Dark toggle — StepButtonStyle with Tag="active" for active state -->
                        <UniformGrid Rows="1" Columns="2" Margin="0,0,0,6">
                            <Button Height="56"
                                    Command="{Binding SettingsVm.SetThemeCommand}"
                                    CommandParameter="Light"
                                    Content="Light"
                                    ToolTip="Switch to Light theme">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource StepButtonStyle}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SettingsVm.IsDarkMode}" Value="False">
                                                <Setter Property="Tag" Value="active"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                            <Button Height="56"
                                    Command="{Binding SettingsVm.SetThemeCommand}"
                                    CommandParameter="Dark"
                                    Content="Dark"
                                    ToolTip="Switch to Dark theme">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource StepButtonStyle}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SettingsVm.IsDarkMode}" Value="True">
                                                <Setter Property="Tag" Value="active"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </UniformGrid>
                    </StackPanel>

                </DockPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
